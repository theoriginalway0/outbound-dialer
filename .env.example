# Dialer mode: mock | twilio | ringcentral | btcloudwork
# BT Cloud Work uses the standard RingCentral API — there are no BT-specific APIs.
# Set up your integration via https://developers.ringcentral.com/
DIALER_MODE=mock

# --- Twilio (when DIALER_MODE=twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TWIML_URL=
TWILIO_STATUS_CALLBACK_URL=

# --- RingCentral / BT Cloud Work (when DIALER_MODE=ringcentral or btcloudwork) ---
RINGCENTRAL_SERVER=https://platform.ringcentral.com
RINGCENTRAL_CLIENT_ID=
RINGCENTRAL_CLIENT_SECRET=
RINGCENTRAL_JWT_TOKEN=
RINGCENTRAL_FROM_NUMBER=

# --- Database ---
DATABASE_URL=sqlite:///./dialer.db
